# Mastodon .env.production — Managed by Ansible (do not edit manually)
LOCAL_DOMAIN={{ mastodon_app_local_domain }}
SINGLE_USER_MODE=false

REDIS_HOST={{ mastodon_redis_hostname }}
REDIS_PORT={{ mastodon_redis_port }}

DB_HOST={{ mastodon_pg_hostname }}
DB_USER={{ mastodon_pg_username }}
DB_NAME={{ mastodon_pg_name }}
DB_PASS={{ mastodon_pg_password }}
DB_PORT={{ mastodon_pg_port }}

ES_ENABLED={{ mastodon_es_enabled }}
ES_HOST={{ mastodon_es_hostname }}
ES_PORT={{ mastodon_es_port }}
ES_USER={{ mastodon_es_username }}
ES_PASS={{ mastodon_es_password }}

SECRET_KEY_BASE={{ mastodon_secret_key_base | default(__rails_secrets[0]) }}
OTP_SECRET={{ mastodon_otp_secret | default(__rails_secrets[1]) }}

VAPID_PRIVATE_KEY={{ mastodon_vapid_private_key | default('') }}
VAPID_PUBLIC_KEY={{ mastodon_vapid_public_key | default('') }}

SMTP_SERVER={{ mastodon_smtp_server }}
SMTP_PORT={{ mastodon_smtp_port }}
SMTP_LOGIN={{ mastodon_smtp_login }}
SMTP_PASSWORD={{ mastodon_smtp_password }}
SMTP_FROM_ADDRESS={{ mastodon_smtp_from_address }}

S3_ENABLED={{ mastodon_s3_enabled }}
S3_BUCKET={{ mastodon_s3_bucket }}
AWS_ACCESS_KEY_ID={{ mastodon_s3_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ mastodon_s3_aws_secret_access_key }}
S3_ALIAS_HOST={{ mastodon_s3_alias_host }}

RAILS_ENV=production
